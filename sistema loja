"""Função para o menu de ações em Clientes."""
def menu_clientes(connection):
    while True:
        choice = exibir_menu_clientes()
        if choice == '1':
            execute_select_query(connection, "Clientes")
        elif choice == '2':
            inserir_cliente(connection)
        elif choice == '3':
            editar_cliente(connection)
        elif choice == '4':
            excluir_cliente(connection)
        elif choice == '5':
            break
        else:
            print("Opção inválida. Tente novamente.")


