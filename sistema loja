"""Executa um SELECT na tabela especificada."""
def execute_select_query(connection, table_name):
    try:
        cursor = connection.cursor()
        query = f"SELECT * FROM {table_name};"
        cursor.execute(query)
        result = cursor.fetchall()


        if result:
            print(f"Dados da tabela {table_name}:")
            for row in result:
                print(row)
        else:
            print(f"Nenhum dado encontrado na tabela {table_name}.")
    except Error as e:
        print(f"Erro ao executar a consulta: {e}")


"""Insere um novo cliente no banco de dados."""
def inserir_cliente(connection):
    try:
        cursor = connection.cursor()
        nome = input("Digite o nome do cliente: ")
        email = input("Digite o email do cliente: ")
        endereco = input("Digite o endereço do cliente: ")


        query = "INSERT INTO Clientes (Nome, Email, Endereço) VALUES (%s, %s, %s)"
        cursor.execute(query, (nome, email, endereco))
        connection.commit()
        print("Cliente inserido com sucesso!")
    except Error as e:
        print(f"Erro ao inserir cliente: {e}")


"""Edita um cliente existente no banco de dados."""
def editar_cliente(connection):
    try:
        cursor = connection.cursor()
        cliente_id = input("Digite o ID do cliente a ser editado: ")
        nome = input("Digite o novo nome do cliente: ")
        email = input("Digite o novo email do cliente: ")
        endereco = input("Digite o novo endereço do cliente: ")


        query = "UPDATE Clientes SET Nome=%s, Email=%s, Endereço=%s WHERE ClienteID=%s"
        cursor.execute(query, (nome, email, endereco, cliente_id))
        connection.commit()
        print("Cliente atualizado com sucesso!")
    except Error as e:
        print(f"Erro ao editar cliente: {e}")


"""Exclui um cliente do banco de dados."""
