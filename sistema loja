def main_menu():
    print("*** SISTEMA ENSINA LOJA ***")
    connection = connect_to_database()
    if not connection:
        return
    while True:
        # Chama a função que exibe o menu e captura a escolha
        choice = exibir_menu()
        if choice == '1':
            menu_clientes(connection)
        elif choice == '2':
            menu_produtos(connection)
        elif choice == '3':
            execute_select_query(connection, "Inventário")
        elif choice == '4':
            execute_select_query(connection, "ItensPedido")
        elif choice == '5':
            execute_select_query(connection, "Pedidos")
        elif choice == '6' or choice.lower() == 'f':
